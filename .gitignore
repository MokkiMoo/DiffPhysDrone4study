__pycache__/
*.py[cod]
*.so

# Local training and evaluation artifacts. The code writes these to
# ../output/DiffphysDrone by default; keep accidental in-repo outputs out of git.
/output/
/Outputs/
/runs/
/repro_runs/
/train/
/eval/
/checkpoints/
/tensorboard/
/validation_code/swarm/exps_*/

# Large local validation assets from release packages.
/validation_code/**/*.tar.gz
/validation_code/**/*.zip
/validation_code/**/LinuxNoEditor/
/validation_code/**/.x11_display

# Generated media, logs, and model checkpoints.
*.mp4
*.avi
*.log
*.pt
*.pth
*.ckpt
